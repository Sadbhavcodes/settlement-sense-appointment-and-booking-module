# =====================================================
# Settlement Sense — Appointments Module
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =====================================================

# Gemini AI API key (used by AI Scheduler feature)
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string (local pgAdmin / Supabase / Neon / etc.)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/settlement_sense

# ── Vapi AI Voice Agent ──────────────────────────────────────────────────────
# Get these from: dashboard.vapi.ai → Account → API Keys
VAPI_API_KEY=your_vapi_private_key
VAPI_ASSISTANT_ID=your_vapi_assistant_id

# Shared secret between Vapi and your server (set same value in Vapi Dashboard
# → Assistant → Advanced → HTTP Headers → key: x-vapi-secret)
VAPI_WEBHOOK_SECRET=your_random_secret_string

# Public key — safe to expose in browser (used by @vapi-ai/web SDK)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your_vapi_assistant_id

# ── Twilio (phone number provider) ──────────────────────────────────────────
# Get these from: console.twilio.com → Account Dashboard
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
