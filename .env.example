# =====================================================
# Settlement Sense — Appointments Module
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =====================================================

# Gemini AI API key (used by AI Scheduler feature)
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string (local pgAdmin / Supabase / Neon / etc.)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/settlement_sense
