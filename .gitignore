# ============================================================
# Settlement Sense — Appointments Module
# .gitignore — only clean source code ships to production
# ============================================================

# --- Secrets (NEVER commit these) ---
.env
.env.*
!.env.example

# --- Test / Dev server (not for production) ---
test-server/

# --- Temporary debug & test scripts ---
test-db.js
check-endpoints.ps1
check-schema-2.js
seed-demo.js

# --- Next.js build output ---
/.next/
/out/
/build/

# --- TypeScript build cache ---
*.tsbuildinfo
tsconfig.tsbuildinfo

# --- Dependencies ---
node_modules/

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- SQLite (was old db, no longer needed) ---
*.db
*.db-shm
*.db-wal